{
  "name": "Ahamove Competitor Intel Alert",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 */6 * * *"
            }
          ]
        }
      },
      "id": "schedule-trigger",
      "name": "Schedule — Every 6h",
      "type": "n8n-nodes-base.scheduleTrigger",
      "position": [200, 300]
    },
    {
      "parameters": {
        "command": "cd /Users/ts-1148/Desktop/Pulu-workspace && python3 _scripts/crawl_competitor_intel.py 2>&1"
      },
      "id": "run-crawler",
      "name": "Run Crawler Script",
      "type": "n8n-nodes-base.executeCommand",
      "position": [420, 300]
    },
    {
      "parameters": {
        "filePath": "/Users/ts-1148/Desktop/Pulu-workspace/Output/Ahamove/06. COMPETITIVE_INTEL/monitoring/raw-signals.json"
      },
      "id": "read-signals",
      "name": "Read Signals JSON",
      "type": "n8n-nodes-base.readBinaryFile",
      "position": [620, 300]
    },
    {
      "parameters": {
        "jsCode": "const data = JSON.parse(Buffer.from($input.first().binary.data.data, 'base64').toString());\nconst cutoff = new Date(Date.now() - 6 * 60 * 60 * 1000).toISOString();\nconst recent = data.filter(s => s.fetched_at > cutoff);\n\nif (!recent.length) return [{ json: { hasNew: false, message: '' } }];\n\n// Group by competitor\nconst byComp = {};\nfor (const s of recent) {\n  if (!byComp[s.competitor]) byComp[s.competitor] = [];\n  byComp[s.competitor].push(s.title);\n}\n\nconst lines = ['⚔️ *Competitor Intel Alert*', ''];\nfor (const [comp, titles] of Object.entries(byComp)) {\n  lines.push(`*${comp}* (${titles.length} tin):`);\n  titles.slice(0, 2).forEach(t => lines.push(`• ${t.substring(0, 80)}`));\n  lines.push('');\n}\nlines.push(`_${recent.length} signals | ${new Date().toLocaleString('vi-VN', {timeZone: 'Asia/Ho_Chi_Minh'})}_`);\n\nreturn [{ json: { hasNew: true, message: lines.join('\\n') } }];"
      },
      "id": "format-intel",
      "name": "Format Intel Message (JS)",
      "type": "n8n-nodes-base.code",
      "position": [820, 300]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{ $json.hasNew }}",
              "value2": true
            }
          ]
        }
      },
      "id": "check-new",
      "name": "Has New Signals?",
      "type": "n8n-nodes-base.if",
      "position": [1020, 300]
    },
    {
      "parameters": {
        "chatId": "={{ $env.TELEGRAM_CHAT_ID }}",
        "text": "={{ $json.message }}",
        "additionalFields": {
          "parse_mode": "Markdown"
        }
      },
      "id": "telegram-alert",
      "name": "Telegram — Send Alert",
      "type": "n8n-nodes-base.telegram",
      "position": [1220, 200],
      "credentials": {
        "telegramApi": {
          "id": "telegram-creds",
          "name": "Telegram Bot"
        }
      }
    }
  ],
  "connections": {
    "Schedule — Every 6h": {
      "main": [[{"node": "Run Crawler Script", "type": "main", "index": 0}]]
    },
    "Run Crawler Script": {
      "main": [[{"node": "Read Signals JSON", "type": "main", "index": 0}]]
    },
    "Read Signals JSON": {
      "main": [[{"node": "Format Intel Message (JS)", "type": "main", "index": 0}]]
    },
    "Format Intel Message (JS)": {
      "main": [[{"node": "Has New Signals?", "type": "main", "index": 0}]]
    },
    "Has New Signals?": {
      "main": [
        [{"node": "Telegram — Send Alert", "type": "main", "index": 0}],
        []
      ]
    }
  },
  "settings": { "executionOrder": "v1" },
  "_meta": {
    "description": "Mỗi 6h: crawler → filter signals mới → JS format → Telegram. Không cần LLM.",
    "requiredCredentials": ["telegramApi"],
    "schedule": "0 */6 * * *"
  }
}
