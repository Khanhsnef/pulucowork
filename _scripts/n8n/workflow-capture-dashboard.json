{
  "name": "Auto Capture Streamlit Dashboard",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 7 * * *"
            }
          ]
        }
      },
      "id": "trigger-schedule",
      "name": "Daily (7AM)",
      "type": "n8n-nodes-base.scheduleTrigger",
      "position": [ 0, 200 ]
    },
    {
      "parameters": {
        "command": "python3 /Users/ts-1148/Desktop/Pulu-workspace/_scripts/sgn_daily_telegram_report.py"
      },
      "id": "run-capture",
      "name": "Capture & Send Telegram",
      "type": "n8n-nodes-base.executeCommand",
      "position": [ 250, 200 ]
    }
  ],
  "connections": {
    "Daily (7AM)": {
      "main": [ [ { "node": "Capture & Send Telegram", "type": "main", "index": 0 } ] ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "_meta": {
    "description": "Trigger SGN Daily Telegram Report (Streamlit Capture)"
  }
}
