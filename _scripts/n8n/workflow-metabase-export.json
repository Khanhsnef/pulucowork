{
  "name": "Auto Capture Dashboard (Metabase Export)",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 6 * * *"
            }
          ]
        }
      },
      "id": "trigger-schedule",
      "name": "Daily (6AM)",
      "type": "n8n-nodes-base.scheduleTrigger",
      "position": [ 0, 200 ]
    },
    {
      "parameters": {
        "command": "python3 /Users/ts-1148/Desktop/Pulu-workspace/_scripts/trigger_metabase_export.py"
      },
      "id": "run-export",
      "name": "Capture Dashboard (Export GS)",
      "type": "n8n-nodes-base.executeCommand",
      "position": [ 250, 200 ]
    }
  ],
  "connections": {
    "Daily (6AM)": {
      "main": [ [ { "node": "Capture Dashboard (Export GS)", "type": "main", "index": 0 } ] ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "_meta": {
    "description": "Trigger Metabase Export to Google Sheets automatically."
  }
}
